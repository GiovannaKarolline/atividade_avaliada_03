package Exercicio1_Usuario;

import java.util.ArrayList;
import java.util.List;

public class TestaUsuarios {

	public static void main(String[] args) {
		List<Usuario> usuarios = new ArrayList<Usuario>();
		
		criarUsuarios(usuarios);
		
		try {
			Administrador adm = new Administrador("ao","ai",2);
		}catch(IllegalArgumentException excessao) {
			System.out.println("Erro: " + excessao.getMessage());
		}
		
		for(Usuario usuario : usuarios) {
			usuario.visualizar();
		}
	}
	
	public static void criarUsuarios(List<Usuario> listaUsuarios) throws Validacao{
		Usuario usuario = new Usuario("a","bece");
		Usuario usuario2 = new Usuario("b","cede");
		Administrador adm = new Administrador("ce","dee", 1);
		listaUsuarios.add(usuario);
		listaUsuarios.add(usuario2);
		listaUsuarios.add(adm);
	}

}
